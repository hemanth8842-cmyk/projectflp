<mvc:View
    controllerName="projectflp.projectflp.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <App id="myApp">

        <Page
            id="firstPage"
            title="Employee Mock Data"
            showFooter="true">

            <content>
                <VBox class="sapUiSmallMargin">

                    <Label text="Name" />
                    <Input
                        id="inpName"
                        placeholder="Enter name"
                        liveChange="onLiveChange" />

                    <Label text="Email" />
                    <Input
                        id="inpEmail"
                        placeholder="Enter email"
                        liveChange="onLiveChange" />

                    <Label text="Phone" />
                    <Input
                        id="inpPhone"
                        placeholder="Enter phone"
                        liveChange="onLiveChange" />

                    <Label text="City" />
                    <Input
                        id="inpCity"
                        placeholder="Enter city"
                        liveChange="onLiveChange" />

                </VBox>
            </content>

            <footer>
                <Toolbar>
                    <ToolbarSpacer />
                    <Button
                        id="submitBtn"
                        text="Submit"
                        type="Emphasized"
                        enabled="false"
                        press="onSubmit" />
                    <Button
                        text="Cancel"
                        type="Reject"
                        press="onCancel" />
                </Toolbar>
            </footer>
        </Page>

        <Page
            id="secondPage"
            title="Image Page"
            showNavButton="true"
            navButtonPress="onPrevious">

            <content>
                <VBox class="sapUiSmallMargin" alignItems="Center" justifyContent="Center">

                    <Image
                        src="/image/office.jpeg"
                        alt="Office Team"
                        width="300px"
                        height="200px"
                        decorative="false"
                        densityAware="false" />

                    <Button
                        text="Previous"
                        type="Emphasized"
                        class="sapUiSmallMarginTop"
                        press="onPrevious" />
                </VBox>
            </content>
        </Page>

    </App>
</mvc:View>